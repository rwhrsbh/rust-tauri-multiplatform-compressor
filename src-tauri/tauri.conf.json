{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GameCompressor",
  "version": "0.1.0",
  "identifier": "com.gamecompressor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Game Compressor",
        "width": 1080,
        "height": 740,
        "minWidth": 880,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Прозрачное сжатие игровых папок",
    "longDescription": "Сжимает игры без потери данных средствами файловой системы: WOF/NTFS на Windows, decmpfs на macOS, Btrfs (zstd) на Linux.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
